---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroInput from '../components/HeroInput.astro';
import MediaWorkspace from '../components/MediaWorkspace.astro';
import HistoryGrid from '../components/HistoryGrid.astro';
import AuthModal from '../components/AuthModal.astro';
---

<Layout
  title="TeraPlay — Stream & Download TeraBox Files"
  description="Bypass forced app blocks. Parse, stream, and download TeraBox links directly in your browser. No ads, no redirects."
  currentPage="/"
>
  <Header currentPage="/" />

  <main class="main">
    <HeroInput />
    <MediaWorkspace />
    <HistoryGrid />
  </main>

  <Footer />
  <AuthModal />
</Layout>

<style>
  .main {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
  }
</style>
