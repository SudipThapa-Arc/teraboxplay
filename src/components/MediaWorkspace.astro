---
// MediaWorkspace — Split panel: Player (65%) + Metadata (35%)
import MediaPlayer from './MediaPlayer.astro';
import MetadataCard from './MetadataCard.astro';
---

<section class="workspace" id="media-workspace" aria-label="Media workspace">
  <div class="workspace__inner container">
    <div class="workspace__panel workspace__panel--player">
      <MediaPlayer />
    </div>
    <div class="workspace__panel workspace__panel--meta">
      <MetadataCard />
    </div>
  </div>
</section>

<script>
  import { $stream } from '../stores/stream';

  function initWorkspace() {
    const workspace = document.getElementById('media-workspace') as HTMLElement;
    if (!workspace) return;

    $stream.subscribe(state => {
      if (state.status !== 'idle') {
        workspace.classList.add('workspace--visible');
        workspace.setAttribute('aria-hidden', 'false');
      } else {
        workspace.classList.remove('workspace--visible');
        workspace.setAttribute('aria-hidden', 'true');
      }
    });
  }

  initWorkspace();
  document.addEventListener('astro:after-swap', initWorkspace);
</script>

<style>
  .workspace {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height var(--duration-slow) var(--ease-out),
                opacity var(--duration-normal) var(--ease-out),
                margin var(--duration-slow) var(--ease-out);
    margin-bottom: 0;
  }

  .workspace--visible {
    max-height: 1200px;
    opacity: 1;
    margin-bottom: var(--spacing-3xl);
  }

  .workspace__inner {
    display: grid;
    grid-template-columns: 65fr 35fr;
    gap: var(--spacing-base);
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
  }

  .workspace__panel--player {
    min-width: 0;
  }

  .workspace__panel--meta {
    min-width: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .workspace__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
