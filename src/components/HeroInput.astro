---
// HeroInput — Center-stage URL input terminal
---

<section class="color-block color-block-lime" id="hero-section">
  <div class="hero__inner">
    <!-- Eyebrow -->
    <p class="text-eyebrow">TERABOX LINK EXTRACTOR</p>

    <!-- Headline -->
    <h1 class="text-display-xl hero__title">
      Stream & Download<br/>
      Without Limits
    </h1>

    <!-- Subtitle -->
    <p class="text-subhead hero__subtitle">
      Bypass forced app blocks. Paste any TeraBox link and get instant direct streaming or download — no ads, no redirects.
    </p>

    <!-- Input Terminal -->
    <div class="hero__terminal" id="hero-terminal">
      <div class="hero__input-wrapper">
        <input
          type="url"
          id="url-input"
          class="hero__input"
          placeholder="https://terabox.com/s/your-link-here"
          autocomplete="off"
          spellcheck="false"
          aria-label="TeraBox URL"
        />
        <button class="btn btn-primary hero__fetch-btn" id="fetch-btn" type="button">
          Fetch & Stream
        </button>
      </div>

      <!-- Loading overlay -->
      <div class="hero__loading" id="hero-loading" aria-hidden="true">
        <div class="hero__loading-bar"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import { $stream, handleFetchLink } from '../stores/stream';

  function initHero() {
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const fetchBtn = document.getElementById('fetch-btn') as HTMLButtonElement;
    const loading = document.getElementById('hero-loading') as HTMLElement;
    const terminal = document.getElementById('hero-terminal') as HTMLElement;

    if (!urlInput || !fetchBtn) return;

    // Fetch handler
    async function onFetch() {
      const url = urlInput.value.trim();
      if (!url) {
        urlInput.focus();
        terminal.classList.add('hero__terminal--error');
        setTimeout(() => terminal.classList.remove('hero__terminal--error'), 600);
        return;
      }
      fetchBtn.disabled = true;
      await handleFetchLink(url);
      fetchBtn.disabled = false;

      // Scroll to workspace
      const workspace = document.getElementById('media-workspace');
      if (workspace) {
        workspace.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    fetchBtn.addEventListener('click', onFetch);
    urlInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') onFetch();
    });

    // Loading state
    $stream.subscribe(state => {
      if (state.status === 'fetching' || state.status === 'resolving') {
        loading.setAttribute('aria-hidden', 'false');
        loading.classList.add('hero__loading--active');
      } else {
        loading.setAttribute('aria-hidden', 'true');
        loading.classList.remove('hero__loading--active');
      }
    });
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>

<style>
  .hero__inner {
    text-align: center;
    max-width: 960px;
    margin: 0 auto;
    padding-block: var(--spacing-xxl);
  }

  .text-eyebrow {
    margin-bottom: var(--spacing-lg);
  }

  .hero__title {
    margin-bottom: var(--spacing-lg);
  }

  .hero__subtitle {
    margin: 0 auto var(--spacing-xxl);
    max-width: 720px;
  }

  /* Terminal input */
  .hero__terminal {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .hero__input-wrapper {
    display: flex;
    align-items: center;
    background-color: var(--color-canvas);
    border-radius: var(--radius-md);
    padding: var(--spacing-xs);
    border: 1px solid var(--color-hairline);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .hero__input-wrapper:focus-within {
    border-color: var(--color-ink);
  }

  .hero__terminal--error .hero__input-wrapper {
    border-color: var(--color-accent-magenta);
    animation: shake 0.3s ease;
  }

  .hero__input {
    flex: 1;
    padding: var(--spacing-md) var(--spacing-lg);
    background: transparent;
    border: none;
    color: var(--color-ink);
    font-size: 18px;
    font-weight: 320;
    outline: none;
  }
  .hero__input::placeholder {
    color: var(--color-hairline);
  }

  .hero__fetch-btn {
    flex-shrink: 0;
    margin-left: var(--spacing-xs);
    white-space: nowrap;
  }

  /* Loading bar */
  .hero__loading {
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 4px;
    overflow: hidden;
    opacity: 0;
    transition: opacity var(--duration-fast);
  }
  .hero__loading--active {
    opacity: 1;
  }
  .hero__loading-bar {
    height: 100%;
    width: 40%;
    background: var(--color-primary);
    animation: loading-sweep 1.2s ease-in-out infinite;
  }

  /* Animations */
  @keyframes loading-sweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(350%); }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__inner {
      padding-block: var(--spacing-lg);
    }

    .hero__input-wrapper {
      flex-direction: column;
      background-color: transparent;
      border: none;
      padding: 0;
      gap: var(--spacing-md);
    }
    
    .hero__input-wrapper:focus-within {
      border-color: transparent;
    }

    .hero__input {
      width: 100%;
      text-align: center;
      background-color: var(--color-canvas);
      border: 1px solid var(--color-hairline);
      border-radius: var(--radius-md);
      padding: var(--spacing-lg);
    }

    .hero__fetch-btn {
      width: 100%;
      margin-left: 0;
      padding-block: 16px;
    }
  }
</style>
