---
interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;
---

<header class="header-wrapper">
  <!-- Top Nav -->
  <div class="top-nav">
    <div class="top-nav__inner">
      <!-- Logo Wordmark -->
      <a href="/" class="logo" aria-label="TeraPlay Home">
        TERAPLAY
      </a>

      <!-- Desktop Nav Links -->
      <nav class="nav-links" aria-label="Main navigation">
        <a href="/" class:list={["nav-link", { "nav-link--active": currentPage === '/' }]}>Home</a>
        <a href="/history" class:list={["nav-link", { "nav-link--active": currentPage === '/history' }]}>History</a>
        <a href="/about" class:list={["nav-link", { "nav-link--active": currentPage === '/about' }]}>About</a>
      </nav>

      <!-- Actions -->
      <div class="actions">
        <!-- User not logged in -->
        <div class="auth-buttons" id="auth-buttons">
          <button class="btn btn-secondary" id="btn-sign-in">Log in</button>
          <button class="btn btn-primary" id="btn-sign-up">Get started for free</button>
        </div>
        
        <!-- User logged in -->
        <div class="user-display" id="user-display" style="display: none;">
          <span class="user-email text-caption" id="user-email"></span>
          <button class="btn btn-secondary" id="btn-logout">Log Out</button>
        </div>

        <button class="hamburger" id="hamburger-btn" aria-label="Toggle menu" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Marquee Strip -->
  <div class="marquee-strip">
    <div class="marquee-content text-caption">
      <span>TERAPLAY ALPHA</span>
      <span class="dot">•</span>
      <span>FETCH LINKS INSTANTLY</span>
      <span class="dot">•</span>
      <span>NO FORCED APP DOWNLOADS</span>
      <span class="dot">•</span>
      <span>DIRECT STREAMING</span>
      <span class="dot">•</span>
      <span>SECURE PARSING</span>
      <span class="dot">•</span>
      <span>TERAPLAY ALPHA</span>
      <span class="dot">•</span>
      <span>FETCH LINKS INSTANTLY</span>
      <span class="dot">•</span>
      <span>NO FORCED APP DOWNLOADS</span>
    </div>
  </div>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      <a href="/" class:list={["mobile-link", { "mobile-link--active": currentPage === '/' }]}>Home</a>
      <a href="/history" class:list={["mobile-link", { "mobile-link--active": currentPage === '/history' }]}>History</a>
      <a href="/about" class:list={["mobile-link", { "mobile-link--active": currentPage === '/about' }]}>About</a>
    </nav>
  </div>
</header>

<script>
  import { $user, openAuth, handleLogout, initAuthState } from '../stores/auth';

  // Hydrate auth session from Supabase on page load
  initAuthState();

  function initHeader() {
    const authButtons = document.getElementById('auth-buttons') as HTMLElement;
    const userDisplay = document.getElementById('user-display') as HTMLElement;
    const userEmail = document.getElementById('user-email') as HTMLElement;
    const hamburgerBtn = document.getElementById('hamburger-btn') as HTMLElement;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

    // Auth state
    $user.subscribe(user => {
      if (user) {
        authButtons.style.display = 'none';
        userDisplay.style.display = 'flex';
        userEmail.textContent = user.email;
      } else {
        authButtons.style.display = 'flex';
        userDisplay.style.display = 'none';
      }
    });

    // Auth button clicks
    document.getElementById('btn-sign-in')?.addEventListener('click', () => openAuth('login'));
    document.getElementById('btn-sign-up')?.addEventListener('click', () => openAuth('signup'));
    document.getElementById('btn-logout')?.addEventListener('click', () => handleLogout());

    // Mobile menu
    hamburgerBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu.getAttribute('aria-hidden') === 'false';
      mobileMenu.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
      hamburgerBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      mobileMenu.classList.toggle('mobile-menu--open', !isOpen);
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
  .header-wrapper {
    position: relative;
    z-index: 100;
  }

  /* Top Nav */
  .top-nav {
    height: 56px;
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    display: flex;
    align-items: center;
    padding-inline: var(--spacing-lg);
  }

  .top-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    gap: var(--spacing-xl);
  }

  /* Logo Wordmark */
  .logo {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--color-ink);
    flex-shrink: 0;
  }

  /* Desktop Nav Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
    flex: 1;
  }

  .nav-link {
    font-size: 16px;
    font-weight: 330;
    color: var(--color-ink);
  }

  .nav-link:hover, .nav-link--active {
    font-weight: 480;
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 4px;
    border-radius: var(--radius-xs);
  }

  /* Actions */
  .actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .auth-buttons, .user-display {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
  }
  .hamburger:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 2px;
    border-radius: var(--radius-xs);
  }

  /* Marquee Strip */
  .marquee-strip {
    height: 36px;
    background-color: var(--color-inverse-canvas);
    color: var(--color-inverse-ink);
    display: flex;
    align-items: center;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
    animation: marquee 20s linear infinite;
  }

  .dot {
    opacity: 0.5;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    position: absolute;
    top: 56px;
    left: 0;
    right: 0;
    background-color: var(--color-canvas);
    padding: var(--spacing-lg);
    border-bottom: 1px solid var(--color-hairline);
    box-shadow: none; /* Design system: no drop shadows */
  }

  .mobile-menu--open {
    display: block;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .mobile-link {
    font-size: 20px;
    font-weight: 330;
    color: var(--color-ink);
    padding-block: var(--spacing-sm);
    border-bottom: 1px solid var(--color-hairline-soft);
  }

  /* Responsive */
  @media (max-width: 960px) {
    .nav-links { display: none; }
    .hamburger { display: block; }
  }

  @media (max-width: 560px) {
    .auth-buttons {
      display: none; /* Hide pills on mobile header, maybe move to mobile menu */
    }
  }
</style>
