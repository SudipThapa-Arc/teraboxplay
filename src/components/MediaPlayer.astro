---
// MediaPlayer — Video/Audio player with console log panel
---

<div class="player" id="player-container">
  <!-- Video element -->
  <div class="player__video-wrapper" id="video-wrapper">
    <video
      id="media-video"
      class="player__video"
      preload="metadata"
      crossorigin="anonymous"
      playsinline
    >
      Your browser does not support the video tag.
    </video>

    <!-- Custom overlay controls -->
    <div class="player__overlay" id="player-overlay">
      <button class="player__play-btn" id="play-btn" aria-label="Play">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle
            cx="24"
            cy="24"
            r="23"
            stroke="currentColor"
            stroke-width="1"
            fill="rgba(0,0,0,0.6)"></circle>
          <path d="M20 16l12 8-12 8V16z" fill="currentColor"></path>
        </svg>
      </button>
    </div>

    <!-- Idle state placeholder -->
    <div class="player__idle" id="player-idle">
      <svg
        width="48"
        height="48"
        viewBox="0 0 48 48"
        fill="none"
        aria-hidden="true"
      >
        <rect
          x="4"
          y="8"
          width="40"
          height="32"
          rx="4"
          stroke="currentColor"
          stroke-width="1.5"
          fill="none"></rect>
        <path d="M20 18l12 6-12 6V18z" fill="currentColor" opacity="0.3"></path>
      </svg>
      <p class="player__idle-text">Paste a link above to start streaming</p>
    </div>

    <!-- Error banner (shown on stream failure) -->
    <div class="player__error" id="player-error" style="display: none;">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M10 6v4M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <p class="player__error-text" id="player-error-text">Stream failed to load.</p>
    </div>
  </div>

  <!-- Audio waveform (shown for audio files) -->
  <div class="player__audio-wrapper" id="audio-wrapper" style="display: none;">
    <audio id="media-audio" preload="metadata" crossorigin="anonymous"></audio>
    <div class="player__waveform" id="audio-waveform">
      <div class="player__wave-bar" style="--h: 40%"></div>
      <div class="player__wave-bar" style="--h: 65%"></div>
      <div class="player__wave-bar" style="--h: 85%"></div>
      <div class="player__wave-bar" style="--h: 55%"></div>
      <div class="player__wave-bar" style="--h: 95%"></div>
      <div class="player__wave-bar" style="--h: 70%"></div>
      <div class="player__wave-bar" style="--h: 50%"></div>
      <div class="player__wave-bar" style="--h: 80%"></div>
      <div class="player__wave-bar" style="--h: 60%"></div>
      <div class="player__wave-bar" style="--h: 90%"></div>
      <div class="player__wave-bar" style="--h: 45%"></div>
      <div class="player__wave-bar" style="--h: 75%"></div>
      <div class="player__wave-bar" style="--h: 85%"></div>
      <div class="player__wave-bar" style="--h: 55%"></div>
      <div class="player__wave-bar" style="--h: 70%"></div>
      <div class="player__wave-bar" style="--h: 60%"></div>
      <div class="player__wave-bar" style="--h: 80%"></div>
      <div class="player__wave-bar" style="--h: 50%"></div>
      <div class="player__wave-bar" style="--h: 90%"></div>
      <div class="player__wave-bar" style="--h: 65%"></div>
    </div>
    <div class="player__audio-controls">
      <button
        class="btn btn-secondary btn-sm"
        id="audio-play-btn"
        aria-label="Play audio"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M4 2l8 5-8 5V2z" fill="currentColor"></path>
        </svg>
      </button>
      <div class="player__audio-progress">
        <div class="player__audio-progress-bar" id="audio-progress-bar"></div>
      </div>
      <span class="player__audio-time mono" id="audio-time">0:00 / 0:00</span>
    </div>
  </div>

  <!-- Controls bar -->
  <div class="player__controls" id="player-controls" style="display: none;">
    <button class="player__ctrl-btn" id="ctrl-play" aria-label="Play/Pause">
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        id="ctrl-play-icon"
      >
        <path d="M5 3l8 5-8 5V3z" fill="currentColor"></path>
      </svg>
    </button>
    <div class="player__progress-bar" id="progress-container">
      <div class="player__progress-fill" id="progress-fill"></div>
      <div class="player__progress-buffer" id="progress-buffer"></div>
    </div>
    <span class="player__time mono" id="time-display">0:00 / 0:00</span>
    <button class="player__ctrl-btn" id="ctrl-volume" aria-label="Mute/Unmute">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path
          d="M3 6h2l3-3v10L5 10H3a1 1 0 01-1-1V7a1 1 0 011-1z"
          fill="currentColor"></path>
        <path
          d="M11 5.5a3 3 0 010 5"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"></path>
      </svg>
    </button>
    <button
      class="player__ctrl-btn"
      id="ctrl-fullscreen"
      aria-label="Fullscreen"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path
          d="M2 5V2h3M11 2h3v3M14 11v3h-3M5 14H2v-3"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>

  <!-- Console log panel -->
  <div class="player__console" id="console-panel">
    <div class="player__console-header">
      <span class="eyebrow">Proxy Console</span>
      <span class="player__console-dot pulse" id="console-dot"></span>
    </div>
    <div class="player__console-output mono" id="console-output">
      <p class="player__console-line player__console-line--dim">
        [READY] Waiting for input...
      </p>
    </div>
  </div>
</div>

<script>
  import { $stream } from "../stores/stream";

  // ─── HLS.js loader ───
  // Loaded lazily only when a .m3u8 manifest is detected.
  let hlsInstance: { destroy(): void } | null = null;

  async function attachHls(videoEl: HTMLVideoElement, src: string): Promise<void> {
    if (hlsInstance) {
      hlsInstance.destroy();
      hlsInstance = null;
    }

    // Load hls.js via a script tag — avoids TypeScript CDN module resolution errors
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const Hls: any = await loadHlsScript();

    if (!Hls || !Hls.isSupported()) {
      // Safari: native HLS support
      videoEl.src = src;
      videoEl.load();
      return;
    }

    const hls = new Hls({ enableWorker: false });
    hls.loadSource(src);
    hls.attachMedia(videoEl);

    hls.on(Hls.Events.ERROR, (_event: string, data: { fatal?: boolean; type?: string; details?: string }) => {
      if (data.fatal) {
        console.error('[HLS] Fatal error:', data.type, data.details);
        showPlayerError(`HLS error: ${data.details ?? data.type ?? 'unknown'}`);
        hls.destroy();
        hlsInstance = null;
      }
    });

    hlsInstance = hls;
  }

  /** Inject hls.js script tag and resolve with the global Hls constructor */
  function loadHlsScript(): Promise<unknown> {
    return new Promise((resolve, reject) => {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      if ((window as any).Hls) { resolve((window as any).Hls); return; }
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/hls.js@1.5.13/dist/hls.min.js';
      script.crossOrigin = 'anonymous';
      script.onload = () => resolve((window as any).Hls); // eslint-disable-line @typescript-eslint/no-explicit-any
      script.onerror = () => reject(new Error('Failed to load hls.js from CDN'));
      document.head.appendChild(script);
    });
  }


  function showPlayerError(msg: string) {
    const errorEl  = document.getElementById('player-error')  as HTMLElement;
    const errorTxt = document.getElementById('player-error-text') as HTMLElement;
    const idle     = document.getElementById('player-idle')    as HTMLElement;
    const overlay  = document.getElementById('player-overlay') as HTMLElement;
    if (errorEl && errorTxt) {
      errorTxt.textContent = msg;
      errorEl.style.display = 'flex';
    }
    if (idle)    idle.style.display = 'none';
    if (overlay) overlay.style.display = 'none';
  }

  function hidePlayerError() {
    const errorEl = document.getElementById('player-error') as HTMLElement;
    if (errorEl) errorEl.style.display = 'none';
  }

  function initPlayer() {
    const videoEl = document.getElementById("media-video") as HTMLVideoElement;
    const audioEl = document.getElementById("media-audio") as HTMLAudioElement;
    const videoWrapper = document.getElementById(
      "video-wrapper",
    ) as HTMLElement;
    const audioWrapper = document.getElementById(
      "audio-wrapper",
    ) as HTMLElement;
    const playerIdle = document.getElementById("player-idle") as HTMLElement;
    const playerOverlay = document.getElementById(
      "player-overlay",
    ) as HTMLElement;
    const playerControls = document.getElementById(
      "player-controls",
    ) as HTMLElement;
    const playBtn = document.getElementById("play-btn") as HTMLButtonElement;
    const ctrlPlay = document.getElementById("ctrl-play") as HTMLButtonElement;
    const ctrlPlayIcon = document.getElementById(
      "ctrl-play-icon",
    ) as unknown as SVGElement;
    const progressFill = document.getElementById(
      "progress-fill",
    ) as HTMLElement;
    const progressContainer = document.getElementById(
      "progress-container",
    ) as HTMLElement;
    const timeDisplay = document.getElementById("time-display") as HTMLElement;
    const consoleOutput = document.getElementById(
      "console-output",
    ) as HTMLElement;
    const consoleDot = document.getElementById("console-dot") as HTMLElement;
    const audioPlayBtn = document.getElementById(
      "audio-play-btn",
    ) as HTMLButtonElement;
    const audioProgressBar = document.getElementById(
      "audio-progress-bar",
    ) as HTMLElement;
    const audioTime = document.getElementById("audio-time") as HTMLElement;
    const ctrlFullscreen = document.getElementById(
      "ctrl-fullscreen",
    ) as HTMLButtonElement;
    const ctrlVolume = document.getElementById(
      "ctrl-volume",
    ) as HTMLButtonElement;

    if (!videoEl) return;

    // Play/Pause state
    $stream.subscribe((state) => {
      // Console log
      if (state.consoleLog.length > 0) {
        consoleOutput.innerHTML = state.consoleLog
          .map((line) => `<p class="player__console-line">${line}</p>`)
          .join("");
        consoleOutput.scrollTop = consoleOutput.scrollHeight;
        consoleDot.style.display = "inline-block";
      }

      if (state.status === "playing") {
        hidePlayerError();
        const srcUrl = state.proxyUrl || state.resolvedUrl;

        if (state.mediaType === "audio") {
          videoWrapper.style.display = "none";
          audioWrapper.style.display = "block";
          playerControls.style.display = "none";
          audioEl.src = srcUrl;
          audioEl.load();
        } else {
          videoWrapper.style.display = "block";
          audioWrapper.style.display = "none";
          playerControls.style.display = "flex";
          playerIdle.style.display = "none";
          playerOverlay.style.display = "flex";

          if (state.isHls) {
            // Async HLS attach — catch and show error gracefully
            attachHls(videoEl, srcUrl).catch((err: unknown) => {
              console.error('[HLS] Load failed:', err);
              showPlayerError('Failed to load HLS stream. Check the URL and try again.');
            });
          } else {
            // Native video
            if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
            videoEl.src = srcUrl;
            videoEl.load();
          }
        }
      } else if (state.status === "idle") {
        if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
        videoWrapper.style.display = "block";
        audioWrapper.style.display = "none";
        playerIdle.style.display = "flex";
        playerOverlay.style.display = "none";
        playerControls.style.display = "none";
        consoleDot.style.display = "none";
        hidePlayerError();
      } else if (state.status === "error") {
        showPlayerError('Resolution failed. Check the console for details.');
      }
    });

    // Play/Pause (video)
    function togglePlay() {
      if (videoEl.paused) {
        videoEl.play();
        playerOverlay.style.opacity = "0";
        ctrlPlayIcon.innerHTML =
          '<rect x="4" y="3" width="3" height="10" rx="1" fill="currentColor"/><rect x="9" y="3" width="3" height="10" rx="1" fill="currentColor"/>';
      } else {
        videoEl.pause();
        playerOverlay.style.opacity = "1";
        ctrlPlayIcon.innerHTML =
          '<path d="M5 3l8 5-8 5V3z" fill="currentColor"/>';
      }
    }

    playBtn?.addEventListener("click", togglePlay);
    ctrlPlay?.addEventListener("click", togglePlay);
    videoEl?.addEventListener("click", togglePlay);

    // Progress
    videoEl?.addEventListener("timeupdate", () => {
      if (videoEl.duration) {
        const pct = (videoEl.currentTime / videoEl.duration) * 100;
        progressFill.style.width = `${pct}%`;
        timeDisplay.textContent = `${formatTime(videoEl.currentTime)} / ${formatTime(videoEl.duration)}`;
      }
    });

    // Seek
    progressContainer?.addEventListener("click", (e) => {
      const rect = progressContainer.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      videoEl.currentTime = pct * videoEl.duration;
    });

    // Fullscreen
    ctrlFullscreen?.addEventListener("click", () => {
      const container = document.getElementById("player-container");
      if (container) {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          container.requestFullscreen();
        }
      }
    });

    // Volume toggle
    ctrlVolume?.addEventListener("click", () => {
      videoEl.muted = !videoEl.muted;
    });

    // Audio controls
    audioPlayBtn?.addEventListener("click", () => {
      if (audioEl.paused) {
        audioEl.play();
        audioPlayBtn.innerHTML =
          '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="3" y="2" width="3" height="10" rx="1" fill="currentColor"/><rect x="8" y="2" width="3" height="10" rx="1" fill="currentColor"/></svg>';
      } else {
        audioEl.pause();
        audioPlayBtn.innerHTML =
          '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 2l8 5-8 5V2z" fill="currentColor"/></svg>';
      }
    });

    audioEl?.addEventListener("timeupdate", () => {
      if (audioEl.duration) {
        const pct = (audioEl.currentTime / audioEl.duration) * 100;
        audioProgressBar.style.width = `${pct}%`;
        audioTime.textContent = `${formatTime(audioEl.currentTime)} / ${formatTime(audioEl.duration)}`;
      }
    });

    function formatTime(s: number): string {
      const mins = Math.floor(s / 60);
      const secs = Math.floor(s % 60);
      return `${mins}:${secs.toString().padStart(2, "0")}`;
    }
  }

  initPlayer();
  document.addEventListener("astro:after-swap", initPlayer);
</script>

<style>
  .player {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-canvas);
  }

  /* Video wrapper */
  .player__video-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    overflow: hidden;
  }

  .player__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Overlay */
  .player__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--duration-normal) var(--ease-out);
    cursor: pointer;
  }

  .player__play-btn {
    background: none;
    border: none;
    color: var(--color-ink);
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast);
    opacity: 0.8;
  }
  .player__play-btn:hover {
    transform: scale(1.1);
    opacity: 1;
  }

  /* Idle state */
  .player__idle {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    color: var(--color-ink);
    opacity: 0.5;
  }
  .player__idle-text {
    font-size: 16px;
    font-weight: 330;
    color: var(--color-ink);
  }

  /* Error banner — Figma: white bg, hairline border, no shadow */
  .player__error {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    background-color: var(--color-canvas);
    color: var(--color-ink);
  }

  .player__error-text {
    font-size: 14px;
    font-weight: 330;
    color: var(--color-ink);
    opacity: 0.7;
    text-align: center;
    max-width: 280px;
    line-height: 1.5;
  }


  /* Audio wrapper */
  .player__audio-wrapper {
    padding: var(--spacing-xxl) var(--spacing-xl);
    background-color: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
  }

  .player__waveform {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 4px;
    height: 120px;
    margin-bottom: var(--spacing-lg);
  }

  .player__wave-bar {
    width: 6px;
    height: var(--h, 50%);
    background-color: var(--color-ink);
    opacity: 0.2;
    border-radius: 3px;
    animation: wave-pulse 1.4s ease-in-out infinite;
    animation-delay: calc(var(--h, 0.5) * 0.8s);
  }

  .player__audio-controls {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .player__audio-progress {
    flex: 1;
    height: 4px;
    background-color: var(--color-hairline);
    border-radius: 2px;
    overflow: hidden;
  }
  .player__audio-progress-bar {
    height: 100%;
    width: 0%;
    background-color: var(--color-ink);
    transition: width 0.1s linear;
  }

  .player__audio-time {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-ink);
    opacity: 0.6;
    white-space: nowrap;
  }

  /* Controls bar */
  .player__controls {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-lg);
    background-color: var(--color-canvas);
  }

  .player__ctrl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    color: var(--color-ink);
    opacity: 0.6;
    cursor: pointer;
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }
  .player__ctrl-btn:hover {
    opacity: 1;
    background-color: var(--color-surface-soft);
  }

  /* Progress */
  .player__progress-bar {
    flex: 1;
    height: 4px;
    background-color: var(--color-hairline);
    border-radius: 2px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .player__progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background-color: var(--color-ink);
    border-radius: 2px;
    transition: width 0.1s linear;
    z-index: 2;
  }
  .player__progress-buffer {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background-color: var(--color-hairline-soft);
    border-radius: 2px;
    z-index: 1;
  }

  .player__time {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-ink);
    opacity: 0.6;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Console panel */
  .player__console {
    border-top: 1px solid var(--color-hairline);
    background-color: var(--color-canvas);
  }
  .player__console-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--color-hairline);
  }
  .player__console-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-success);
    display: none;
  }
  .player__console-output {
    padding: var(--spacing-sm) var(--spacing-lg);
    max-height: 120px;
    overflow-y: auto;
    font-size: 12px;
    font-family: var(--font-mono);
    line-height: 1.7;
  }
  .player__console-line {
    color: var(--color-semantic-success);
  }
  .player__console-line--dim {
    color: var(--color-ink);
    opacity: 0.5;
  }

  /* Wave animation */
  @keyframes wave-pulse {
    0%,
    100% {
      transform: scaleY(1);
      opacity: 0.5;
    }
    50% {
      transform: scaleY(0.6);
      opacity: 0.8;
    }
  }
</style>
