---
import { MOCK_HISTORY } from '../stores/mockData';
const historyRecords = MOCK_HISTORY;
---

<section class="color-block color-block-navy history" id="history-section">
  <div class="history__inner">
    <!-- Header -->
    <div class="history__header">
      <div class="history__title-row">
        <h2 class="history__title text-headline">Recent Links</h2>
        <span class="history__count text-caption" id="history-count">{historyRecords.length} records</span>
      </div>

      <!-- Filter tabs -->
      <div class="history__filters" id="history-filters">
        <button class="history__filter-btn history__filter-btn--active" data-filter="all">All</button>
        <button class="history__filter-btn" data-filter="video">Videos</button>
        <button class="history__filter-btn" data-filter="audio">Audio</button>
        <button class="history__filter-btn" data-filter="document">Docs</button>
      </div>
    </div>

    <!-- Table (desktop) -->
    <div class="history__table-wrapper">
      <table class="history__table" id="history-table">
        <thead>
          <tr>
            <th class="history__th">File Name</th>
            <th class="history__th">Size</th>
            <th class="history__th">Type</th>
            <th class="history__th">Date</th>
            <th class="history__th history__th--action">Action</th>
          </tr>
        </thead>
        <tbody id="history-tbody">
          {historyRecords.map((record) => (
            <tr class="history__row" data-type={record.media_type} data-id={record.id}>
              <td class="history__td history__td--name">
                <span class="history__file-icon" data-media-type={record.media_type}></span>
                <span class="history__filename text-body-sm">{record.file_name}</span>
              </td>
              <td class="history__td history__td--size text-caption">{record.file_size}</td>
              <td class="history__td history__td--type">
                <span class={`badge badge--${record.media_type}`}>
                  {record.media_type}
                </span>
              </td>
              <td class="history__td history__td--date text-caption">{new Date(record.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</td>
              <td class="history__td history__td--action">
                <button class="btn btn-secondary history__restream-btn" data-url={record.original_url}>
                  Re-stream
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Cards (mobile) -->
    <div class="history__cards" id="history-cards">
      {historyRecords.map((record) => (
        <div class="history__card" data-type={record.media_type} data-id={record.id}>
          <div class="history__card-header">
            <span class={`badge badge--${record.media_type}`}>
              {record.media_type}
            </span>
            <span class="history__card-date text-caption">{new Date(record.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          </div>
          <p class="history__card-name text-body-sm">{record.file_name}</p>
          <div class="history__card-footer">
            <span class="history__card-size text-caption">{record.file_size}</span>
            <button class="btn btn-secondary history__restream-btn" data-url={record.original_url} style="min-height: 32px; padding: 4px 12px; font-size: 14px;">
              Re-stream
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { $historyFilter, setHistoryFilter, type HistoryFilter } from '../stores/history';
  import { handleFetchLink } from '../stores/stream';

  function initHistoryGrid() {
    const filtersContainer = document.getElementById('history-filters') as HTMLElement;
    const rows = document.querySelectorAll('.history__row');
    const cards = document.querySelectorAll('.history__card');
    const countEl = document.getElementById('history-count') as HTMLElement;

    filtersContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.history__filter-btn') as HTMLElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter as HistoryFilter;
      setHistoryFilter(filter);
    });

    $historyFilter.subscribe(filter => {
      filtersContainer?.querySelectorAll('.history__filter-btn').forEach(btn => {
        const f = (btn as HTMLElement).dataset.filter;
        btn.classList.toggle('history__filter-btn--active', f === filter);
      });

      let visibleCount = 0;
      rows.forEach(row => {
        const type = (row as HTMLElement).dataset.type;
        const show = filter === 'all' || type === filter;
        (row as HTMLElement).style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      cards.forEach(card => {
        const type = (card as HTMLElement).dataset.type;
        const show = filter === 'all' || type === filter;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });

      countEl.textContent = `${visibleCount} records`;
    });

    document.querySelectorAll('.history__restream-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url;
        if (url) {
          handleFetchLink(url);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });
  }

  initHistoryGrid();
  document.addEventListener('astro:after-swap', initHistoryGrid);
</script>

<style>
  .history__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .history__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    flex-wrap: wrap;
    gap: var(--spacing-base);
  }

  .history__title-row {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
  }

  .history__count {
    opacity: 0.6;
  }

  /* Filters */
  .history__filters {
    display: flex;
    gap: var(--spacing-xxs);
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-pill);
    padding: var(--spacing-xxs);
  }

  .history__filter-btn {
    padding: var(--spacing-xs) var(--spacing-md);
    background: transparent;
    border: none;
    border-radius: var(--radius-pill);
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    font-family: var(--font-sans);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }
  .history__filter-btn:hover {
    color: var(--color-inverse-ink);
  }
  .history__filter-btn--active {
    background-color: var(--color-inverse-ink);
    color: var(--color-ink);
  }
  .history__filter-btn:focus-visible {
    outline: 2px solid var(--color-inverse-ink);
    outline-offset: 2px;
  }

  /* Table */
  .history__table-wrapper {
    overflow-x: auto;
  }

  .history__table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .history__th {
    padding: var(--spacing-sm) var(--spacing-lg);
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
    background-color: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    white-space: nowrap;
  }
  .history__th--action {
    text-align: right;
  }

  /* Vertical column rules */
  .history__th + .history__th,
  .history__td + .history__td {
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }

  .history__row {
    transition: background-color var(--duration-fast) var(--ease-out);
  }
  .history__row:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }
  .history__row + .history__row .history__td {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .history__td {
    padding: var(--spacing-sm) var(--spacing-lg);
    vertical-align: middle;
    white-space: nowrap;
  }

  .history__td--name {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    max-width: 300px;
  }
  .history__filename {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .history__file-icon {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.6);
    flex-shrink: 0;
  }

  .history__td--size {
    color: rgba(255, 255, 255, 0.6);
  }

  .history__td--date {
    color: rgba(255, 255, 255, 0.4);
  }

  .history__td--action {
    text-align: right;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  /* Cards (mobile) */
  .history__cards {
    display: none;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .history__card {
    padding: var(--spacing-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    background-color: rgba(255, 255, 255, 0.05);
  }

  .history__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }
  .history__card-date {
    color: rgba(255, 255, 255, 0.4);
  }
  .history__card-name {
    font-weight: 500;
    margin-bottom: var(--spacing-lg);
    word-break: break-all;
  }
  .history__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .history__card-size {
    color: rgba(255, 255, 255, 0.6);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .history__table-wrapper {
      display: none;
    }
    .history__cards {
      display: flex;
    }
    .history__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .history__restream-btn {
    min-height: 32px;
    padding: 4px 12px;
    font-size: 14px;
  }
  .history__restream-btn:focus-visible {
    outline: 2px solid var(--color-inverse-ink);
    outline-offset: 2px;
  }
</style>
