---
// HistoryGrid — Tabular data with filters and vertical column rules
import { MOCK_HISTORY } from '../stores/mockData';

const historyRecords = MOCK_HISTORY;
---

<section class="history" id="history-section">
  <div class="history__inner container">
    <!-- Header -->
    <div class="history__header">
      <div class="history__title-row">
        <h2 class="history__title">Recent Links</h2>
        <span class="history__count mono" id="history-count">{historyRecords.length} records</span>
      </div>

      <!-- Filter tabs -->
      <div class="history__filters" id="history-filters">
        <button class="history__filter-btn history__filter-btn--active" data-filter="all">All</button>
        <button class="history__filter-btn" data-filter="video">Videos</button>
        <button class="history__filter-btn" data-filter="audio">Audio</button>
        <button class="history__filter-btn" data-filter="document">Docs</button>
      </div>
    </div>

    <!-- Table (desktop) -->
    <div class="history__table-wrapper">
      <table class="history__table" id="history-table">
        <thead>
          <tr>
            <th class="history__th">File Name</th>
            <th class="history__th">Size</th>
            <th class="history__th">Type</th>
            <th class="history__th">Date</th>
            <th class="history__th history__th--action">Action</th>
          </tr>
        </thead>
        <tbody id="history-tbody">
          {historyRecords.map((record) => (
            <tr class="history__row" data-type={record.media_type} data-id={record.id}>
              <td class="history__td history__td--name">
                <span class="history__file-icon" data-media-type={record.media_type}></span>
                <span class="history__filename">{record.file_name}</span>
              </td>
              <td class="history__td history__td--size mono">{record.file_size}</td>
              <td class="history__td history__td--type">
                <span class={`badge badge--${record.media_type === 'video' ? 'info' : record.media_type === 'audio' ? 'warning' : 'success'}`}>
                  {record.media_type}
                </span>
              </td>
              <td class="history__td history__td--date mono">{new Date(record.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</td>
              <td class="history__td history__td--action">
                <button class="btn btn-ghost btn-sm history__restream-btn" data-url={record.original_url}>
                  Re-stream
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Cards (mobile) -->
    <div class="history__cards" id="history-cards">
      {historyRecords.map((record) => (
        <div class="history__card card" data-type={record.media_type} data-id={record.id}>
          <div class="history__card-header">
            <span class={`badge badge--${record.media_type === 'video' ? 'info' : record.media_type === 'audio' ? 'warning' : 'success'}`}>
              {record.media_type}
            </span>
            <span class="history__card-date mono">{new Date(record.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          </div>
          <p class="history__card-name">{record.file_name}</p>
          <div class="history__card-footer">
            <span class="history__card-size mono">{record.file_size}</span>
            <button class="btn btn-secondary btn-sm history__restream-btn" data-url={record.original_url}>
              Re-stream
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { $historyFilter, setHistoryFilter, type HistoryFilter } from '../stores/history';
  import { handleFetchLink } from '../stores/stream';

  function initHistoryGrid() {
    const filtersContainer = document.getElementById('history-filters') as HTMLElement;
    const rows = document.querySelectorAll('.history__row');
    const cards = document.querySelectorAll('.history__card');
    const countEl = document.getElementById('history-count') as HTMLElement;

    // Filter buttons
    filtersContainer?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.history__filter-btn') as HTMLElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter as HistoryFilter;
      setHistoryFilter(filter);
    });

    // Subscribe to filter changes
    $historyFilter.subscribe(filter => {
      // Update button states
      filtersContainer?.querySelectorAll('.history__filter-btn').forEach(btn => {
        const f = (btn as HTMLElement).dataset.filter;
        btn.classList.toggle('history__filter-btn--active', f === filter);
      });

      // Filter rows
      let visibleCount = 0;
      rows.forEach(row => {
        const type = (row as HTMLElement).dataset.type;
        const show = filter === 'all' || type === filter;
        (row as HTMLElement).style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      // Filter cards
      cards.forEach(card => {
        const type = (card as HTMLElement).dataset.type;
        const show = filter === 'all' || type === filter;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });

      countEl.textContent = `${visibleCount} records`;
    });

    // Re-stream buttons
    document.querySelectorAll('.history__restream-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const url = (btn as HTMLElement).dataset.url;
        if (url) {
          handleFetchLink(url);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });

    // File icons
    document.querySelectorAll('.history__file-icon').forEach(icon => {
      const type = (icon as HTMLElement).dataset.mediaType;
      if (type === 'video') {
        icon.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="3" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1"/><path d="M5.5 6v2l2-1-2-1z" fill="currentColor"/></svg>';
      } else if (type === 'audio') {
        icon.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1"/><circle cx="7" cy="7" r="2" fill="currentColor"/></svg>';
      } else {
        icon.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 1h4l3 3v8a1 1 0 01-1 1H4a1 1 0 01-1-1V2a1 1 0 011-1z" stroke="currentColor" stroke-width="1"/><path d="M8 1v3h3" stroke="currentColor" stroke-width="1"/></svg>';
      }
    });
  }

  initHistoryGrid();
  document.addEventListener('astro:after-swap', initHistoryGrid);
</script>

<style>
  .history {
    padding: var(--spacing-3xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .history__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    flex-wrap: wrap;
    gap: var(--spacing-base);
  }

  .history__title-row {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-sm);
  }

  .history__title {
    font-size: var(--text-heading-3);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .history__count {
    font-size: var(--text-caption);
    color: var(--color-ink-faint);
  }

  /* Filters */
  .history__filters {
    display: flex;
    gap: var(--spacing-xxs);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-xxs);
  }

  .history__filter-btn {
    padding: var(--spacing-xs) var(--spacing-sm);
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--color-ink-muted);
    font-size: var(--text-caption);
    font-family: var(--font-sans);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }
  .history__filter-btn:hover {
    color: var(--color-ink);
  }
  .history__filter-btn--active {
    background-color: var(--color-accent);
    color: var(--color-canvas);
  }

  /* Table */
  .history__table-wrapper {
    overflow-x: auto;
  }

  .history__table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .history__th {
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-ink-muted);
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }
  .history__th--action {
    text-align: right;
  }

  /* Vertical column rules */
  .history__th + .history__th,
  .history__td + .history__td {
    border-left: 1px solid var(--color-border-subtle);
  }

  .history__row {
    transition: background-color var(--duration-fast) var(--ease-out);
  }
  .history__row:hover {
    background-color: var(--color-surface);
  }
  .history__row + .history__row .history__td {
    border-top: 1px solid var(--color-border-subtle);
  }

  .history__td {
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--text-body-sm);
    vertical-align: middle;
    white-space: nowrap;
  }

  .history__td--name {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    max-width: 300px;
  }
  .history__filename {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .history__file-icon {
    display: inline-flex;
    color: var(--color-ink-muted);
    flex-shrink: 0;
  }

  .history__td--size {
    color: var(--color-ink-muted);
    font-size: var(--text-caption);
  }

  .history__td--date {
    color: var(--color-ink-faint);
    font-size: var(--text-caption);
  }

  .history__td--action {
    text-align: right;
  }

  /* Cards (mobile) */
  .history__cards {
    display: none;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .history__card {
    padding: var(--spacing-base);
  }

  .history__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }
  .history__card-date {
    font-size: var(--text-caption);
    color: var(--color-ink-faint);
  }
  .history__card-name {
    font-size: var(--text-body-sm);
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
    word-break: break-all;
  }
  .history__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .history__card-size {
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .history__table-wrapper {
      display: none;
    }
    .history__cards {
      display: flex;
    }
    .history__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
